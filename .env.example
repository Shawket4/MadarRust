# Copy to .env and fill in real values.
# NEVER commit .env to version control.

DATABASE_URL=postgres://sufrix:<password>@<host>:5432/sufrix

# Must be a long random string — generate with: openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>

RUST_LOG=info
UPLOADS_DIR=./uploads
UPLOADS_BASE_URL=https://your-domain.com/uploads
BIND_ADDR=0.0.0.0:8080

# TLS — point to your Let's Encrypt certs (or comment out to run plain HTTP behind a proxy)
SSL_CERT_FILE=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_FILE=/etc/letsencrypt/live/your-domain.com/privkey.pem
HTTPS_PORT=8443

# Translation
GOOGLE_TRANSLATE_API_KEY=<your-key>
SUPPORTED_LANGUAGES=en,ar

# PRODUCTION: leave this unset or false.
# Swagger UI exposes the full API surface unauthenticated.
# If you need it in staging, put nginx basic-auth in front of /api-docs/.
SUFRIX_ENABLE_SWAGGER_UI=false
