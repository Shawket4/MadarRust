# Copy to .env and fill in real values.
# NEVER commit .env to version control.
#
# Docker note: DATABASE_URL must use host.docker.internal (not localhost)
# when the backend runs in a container on the VPS.
# Example: postgres://sufrix:<password>@host.docker.internal:5432/sufrix

DATABASE_URL=postgres://sufrix:<password>@host.docker.internal:5432/sufrix

# Local dev only (docker-compose.dev.yml overrides DATABASE_URL with this):
DEV_DATABASE_URL=postgres://sufrix:<password>@host.docker.internal:5432/sufrix_dev

# Must be a long random string — generate with: openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>

RUST_LOG=info
BIND_ADDR=0.0.0.0:8081
UPLOADS_DIR=./uploads
UPLOADS_BASE_URL=https://sufrix.duckdns.org/api/uploads

# WhatsApp gateway (container-network address set by docker-compose.yml;
# WHATSAPP_AUTH_HEADER must match WA_AUTH_TOKEN in the whatsapp container)
WHATSAPP_AUTH_HEADER=<shared-secret>
WHATSAPP_SESSION=main

# Shlink short-URL service (SHLINK_BASE_URL overridden by compose to http://shlink:8080;
# SHLINK_API_KEY is also used by the Shlink container as INITIAL_API_KEY)
SHLINK_API_KEY=<your-shlink-api-key>

# Public base URL for delivery tracking links sent over WhatsApp
PUBLIC_ORDER_BASE_URL=https://sufrix.duckdns.org

# Translation (optional — leave blank to disable auto-translation)
GOOGLE_TRANSLATE_API_KEY=
SUPPORTED_LANGUAGES=en,ar

# PRODUCTION: keep false. Swagger UI exposes the full API surface unauthenticated.
SUFRIX_ENABLE_SWAGGER_UI=false
