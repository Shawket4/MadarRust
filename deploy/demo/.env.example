# /opt/madar-demo/.env — demo backend config. ONE-TIME setup on the VPS.
# Isolated from prod: separate database, DEMO_MODE on, no outbound integrations.
# Reuse the prod Postgres credentials but point at the SEPARATE madar_demo DB.

DATABASE_URL=postgres://madar:<prod-db-password>@host.docker.internal:5432/madar_demo

# Generate a fresh secret (do NOT reuse prod's): openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>

# Demo playground knobs
DEMO_MODE=1
DEMO_TTL_HOURS=24
DEMO_MAX_ORGS=200
DEMO_SWEEP_SECS=300

RUST_LOG=info
BIND_ADDR=0.0.0.0:8081
UPLOADS_DIR=/app/uploads
UPLOADS_BASE_URL=https://demo-api.madar-pos.cloud/api/uploads
CORS_ALLOWED_ORIGINS=https://demo.madar-pos.cloud
PUBLIC_ORDER_BASE_URL=https://demo.madar-pos.cloud
MADAR_ENABLE_SWAGGER_UI=false

# WHATSAPP_SERVICE_URL intentionally UNSET — demo neuters all outbound WhatsApp/OTP
# regardless (DEMO_MODE guard), this is belt-and-suspenders.
